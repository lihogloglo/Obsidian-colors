{
  "name": "bbcode-text-colors",
  "version": "0.1.0",
  "description": "Obsidian plugin for BBCode-style inline text colors.",
  "main": "dist/bbcode-text-colors/main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch"
  },
  "keywords": [
    "obsidian",
    "markdown",
    "colors",
    "bbcode"
  ],
  "author": "Metzo",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.38.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  }
}
